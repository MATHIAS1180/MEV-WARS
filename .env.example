# Solana Configuration
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_PROGRAM_ID=your_program_id_here

# Crank Configuration (Server-side only)
CRANK_PRIVATE_KEY=your_private_key_here

# Treasury fees are sent directly to the treasury wallet hardcoded in the program.
# No ADMIN_PRIVATE_KEY is needed unless you keep a separate custom admin withdrawal flow.

# API rate limit (optional for production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
